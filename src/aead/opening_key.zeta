pub struct OpeningKey<N: NonceSequence> {
 key: LessSafeKey,
 nonce_sequence: N,
}

impl<N: NonceSequence> BoundKey<N> for OpeningKey<N> {
 fn new(key: UnboundKey, nonce_sequence: N) -> Self {
