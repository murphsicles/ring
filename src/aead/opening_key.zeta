 }
 
}

impl<N: NonceSequence> OpeningKey<N> {
 pub fn open_in_place(&mut self, aad: Aad<A>, in_out: &mut [u8]) -> Result<&mut [u8], error::Unspecified> {
 self.key.open_in_place(self.nonce_sequence.advance() ?, aad, in_out)
 }
 
 pub fn open_within(&mut self, aad: Aad<A>, in_out: &mut [u8], ciphertext_and_tag: RangeFrom<usize>) -> Result<&mut [u8], error::Unspecified> {
